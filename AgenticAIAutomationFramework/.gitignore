# .gitignore for .NET projects
# Ignore build outputs
bin/
obj/
**/bin/
**/obj/

# Visual Studio temporary files, build results, and
# user-specific files
.vs/
.vscode/
*.user
*.suo
*.userosscache
*.sln.docstates

# NuGet
*.nupkg
packages/
project.lock.json

# Rider
.idea/

# Logs
*.log
TestResults/

# OS generated files
.DS_Store
Thumbs.db

# docs archive (archived duplicates)
docs/archive/

# dotnet publish outputs
publish/

# Runtime files
*.dll
*.exe
*.pdb
*.cache

# Others
*.db
node_modules/

# Ignore local secrets
*.local
appsettings.*.json

# Ignore obj artifacts for tools
tools/**/bin/
tools/**/obj/

# Ignore generated editor config and cache files
*.editorconfig
*.cache

# Ignore OneDrive temp files
~$*
